<resources>

	<declare-styleable name="NavigationChart">
		<attr name="navChartDrawColor" format="color"/>
	</declare-styleable>
	<!-- Base application theme. -->
	<style name="AppTheme" parent="android:Theme.Holo">
		<item name="navChartDrawColor">#FFFFFF</item>
		<item name="android:buttonStyle">@style/ST2RetroButton</item>
	</style>

	<style name="AppTheme.Light" parent="android:Theme.Holo.Light.DarkActionBar">
		<item name="navChartDrawColor">#000000</item>
		<item name="android:buttonStyle">@style/ST2RetroButton</item>
	</style>

	<style name="BuySellButtons">
		<item name="android:minHeight">0dp</item>
		<item name="android:minWidth">0dp</item>
	</style>


	<style name="ST2RetroButton" parent="@android:style/Widget.Button">
		<item name="android:background">@drawable/st2_button_retro</item>
		<item name="android:textColor">#000000</item>
		<item name="android:textAllCaps">false</item>
		<item name="android:minHeight">0dp</item>
		<item name="android:minWidth">0dp</item>
		<item name="android:paddingLeft">4dp</item>
		<item name="android:paddingRight">4dp</item>
		<item name="android:paddingTop">2dp</item>
		<item name="android:paddingBottom">2dp</item>
	</style>
</resources>
