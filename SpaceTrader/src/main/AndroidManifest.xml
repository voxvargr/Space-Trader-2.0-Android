<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          android:versionCode="144"
          android:versionName="1.4.4">

	<uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28"/>
	<uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>

	<application
			android:allowBackup="true"
			android:icon="@drawable/spacetrader"
			android:label="@string/app_name">
		<activity
				android:name="de.anderdonau.spacetrader.Main"
				android:exported="false"
				android:label="@string/app_name"
				android:screenOrientation="portrait"/>

		<!-- Explicit launcher alias for modern Android launchers.
		     The old port relied on the activity intent-filter directly, but some
		     modern installs can treat that as non-launchable after the Gradle/AGP
		     migration. This alias gives Android a clear exported launcher entry. -->
		<activity-alias
				android:name="de.anderdonau.spacetrader.Launcher"
				android:enabled="true"
				android:exported="true"
				android:icon="@drawable/spacetrader"
				android:label="@string/app_name"
				android:targetActivity="de.anderdonau.spacetrader.Main">
			<intent-filter>
				<action android:name="android.intent.action.MAIN"/>
				<category android:name="android.intent.category.LAUNCHER"/>
			</intent-filter>
		</activity-alias>
	</application>

</manifest>
